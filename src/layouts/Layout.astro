---
import '../styles/globals.css';

interface Props {
	title: string;
	hideNav?: boolean;
}

const { title, hideNav = false } = Astro.props;
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const isAdmin = profile?.role === 'admin';
const isBanned = profile?.is_banned || false;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Elite Real-time Chat Experience" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title} — Elite</title>
	</head>
	<body class="bg-white text-elite-black h-screen flex flex-col font-sans selection:bg-elite-black selection:text-white">
		{isBanned && user ? (
			<div class="bg-elite-black text-white py-2 px-4 text-center text-xs font-bold uppercase tracking-widest border-b border-white/20">
				ACCESS DENIED: Account Banned.
			</div>
		) : null}
		{!hideNav && (
			<nav class="bg-white border-b border-elite-black sticky top-0 z-50">
				<div class="max-w-screen-2xl mx-auto px-6">
					<div class="flex justify-between h-20">
						<div class="flex items-center gap-12">
							<a href="/" class="flex-shrink-0 flex items-center group">
								<span class="text-2xl font-black tracking-tightest uppercase group-hover:bg-elite-black group-hover:text-white px-2 transition-all">ChatTogether</span>
							</a>
							{user && !isBanned && (
								<div class="hidden md:flex gap-8">
									<a href="/chat" class="text-xs font-black uppercase tracking-tighter hover:line-through">Messages</a>
									<a href="/chat/rooms" class="text-xs font-black uppercase tracking-tighter hover:line-through">Communities</a>
									<a href="/profile" class="text-xs font-black uppercase tracking-tighter hover:line-through">Profile</a>
									{isAdmin && (
										<a href="/admin" class="text-xs font-black uppercase tracking-tighter hover:line-through underline decoration-2">Admin</a>
									)}
								</div>
							)}
						</div>
						<div class="flex items-center gap-6">
							{user ? (
								<div class="flex items-center gap-6">
									<span class="text-[10px] font-mono uppercase text-elite-neutral-400">{user.email}</span>
									<form action="/api/auth/signout" method="post">
										<button type="submit" class="text-xs font-black uppercase tracking-tighter border-b-2 border-elite-black hover:bg-elite-black hover:text-white transition-all px-1">Log Out</button>
									</form>
								</div>
							) : (
								<div class="flex items-center gap-4">
									<a href="/login" class="text-xs font-black uppercase tracking-tighter hover:line-through">Login</a>
									<a href="/signup" class="elite-button !py-2 !px-4 text-[10px]">Sign Up</a>
								</div>
							)}
						</div>
					</div>
				</div>
			</nav>
		)}

		<main class="flex-1 overflow-hidden flex flex-col bg-elite-neutral-50/30">
			<slot />
		</main>
	</body>
</html>