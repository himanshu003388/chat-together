---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user?.id)
  .maybeSingle();

let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const username = formData.get('username')?.toString();
    const bio = formData.get('bio')?.toString();
    const avatarFile = formData.get('avatar') as File;
    
    let avatar_url = profile?.avatar_url;

    if (avatarFile && avatarFile.size > 0) {
      const fileExt = avatarFile.name.split('.').pop();
      const fileName = `${user?.id}-${Math.random()}.${fileExt}`;
      
      const { error: uploadError } = await supabase.storage
        .from('avatars')
        .upload(fileName, avatarFile);

      if (uploadError) throw uploadError;
      
      avatar_url = fileName;
    }

    const { error: updateError } = await supabase
      .from('profiles')
      .update({ username, bio, avatar_url })
      .eq('id', user?.id);

    if (updateError) throw updateError;
    
    return Astro.redirect('/profile');
  } catch (error: any) {
    errorMessage = error.message;
  }
}
---

<Layout title="Modify Protocol">
	<div class="max-w-4xl mx-auto py-20 px-8 w-full flex flex-col gap-12">
		<div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b-3 border-elite-black pb-12">
			<div>
				<span class="text-[10px] font-black uppercase tracking-[0.3em] text-elite-neutral-400 mb-2 block">System Configuration</span>
				<h1 class="text-6xl font-black text-elite-black tracking-tightest uppercase leading-none">Settings</h1>
			</div>
			<a href="/profile" class="text-xs font-black uppercase tracking-widest hover:line-through">
				ABORT CHANGES
			</a>
		</div>

		<div class="bg-white elite-border overflow-hidden shadow-[16px_16px_0px_0px_rgba(0,0,0,0.03)] p-12">
			{errorMessage && (
				<div class="bg-elite-black text-white p-6 elite-border mb-12 shadow-[8px_8px_0px_0px_rgba(0,0,0,0.1)]">
					<p class="text-[10px] font-black uppercase tracking-widest">{errorMessage}</p>
				</div>
			)}

			<form method="post" enctype="multipart/form-data" class="space-y-12">
				<div class="space-y-6">
					<label class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Signal Avatar</label>
					<div class="flex items-center gap-10">
						<div class="h-24 w-24 elite-border overflow-hidden bg-elite-neutral-50 flex items-center justify-center p-1">
							{profile?.avatar_url ? (
								<img src={`${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/avatars/${profile.avatar_url}`} alt="" class="h-full w-full object-cover" />
							) : (
								<div class="w-full h-full bg-elite-black flex items-center justify-center text-white font-black text-3xl">
									{profile?.username?.charAt(0).toUpperCase()}
								</div>
							)}
						</div>
						<div class="flex-1">
							<input type="file" name="avatar" id="avatar-input" accept="image/*" class="hidden" />
							<label for="avatar-input" class="elite-button inline-block cursor-pointer text-xs">UPLOAD NEW DATA</label>
							<p class="mt-3 text-[8px] font-mono font-bold text-elite-neutral-400 uppercase tracking-widest">JPG, PNG, GIF • MAX 2MB</p>
						</div>
					</div>
				</div>

				<div class="space-y-4">
					<label for="username" class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Identity Alias</label>
					<input type="text" name="username" id="username" value={profile?.username} required class="w-full bg-elite-neutral-50 elite-border px-8 py-5 focus:bg-white focus:ring-12 focus:ring-elite-black/5 transition-all outline-none font-black text-xs uppercase tracking-tighter" />
				</div>

				<div class="space-y-4">
					<label for="bio" class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Transmission Bio</label>
					<textarea id="bio" name="bio" rows="4" class="w-full bg-elite-neutral-50 elite-border px-8 py-5 focus:bg-white focus:ring-12 focus:ring-elite-black/5 transition-all outline-none font-medium text-sm italic" placeholder="TELL THE NETWORK ABOUT YOURSELF...">{profile?.bio}</textarea>
				</div>

				<div class="pt-8 border-t border-elite-neutral-100 flex justify-end">
					<button type="submit" class="elite-button bg-elite-black text-white text-lg py-5 px-12 shadow-[8px_8px_0px_0px_rgba(0,0,0,0.2)] hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:-translate-x-1 hover:-translate-y-1 transition-all">
						COMMIT PROTOCOL CHANGES
					</button>
				</div>
			</form>
		</div>
	</div>
</Layout>
