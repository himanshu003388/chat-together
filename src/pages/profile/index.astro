---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user?.id)
  .maybeSingle();

---

<Layout title="Profile">
	<div class="max-w-2xl mx-auto py-12 px-6">
		<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
			<div>
				<p class="text-sm text-white/40 font-mono mb-2">Your Profile</p>
				<h1 class="text-4xl font-bold">Account Settings</h1>
			</div>
			<a href="/profile/edit" class="btn-secondary">
				Edit Profile
			</a>
		</div>

		<div class="glass-card p-8">
			<div class="flex flex-col items-center mb-8">
				{profile?.avatar_url ? (
					<img src={`${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/avatars/${profile.avatar_url}`} alt="" class="w-24 h-24 rounded-2xl object-cover border-2 border-accent-cyan/30 mb-4" />
				) : (
					<div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-accent-cyan to-accent-purple flex items-center justify-center text-3xl font-bold mb-4 shadow-glow-cyan">
						{profile?.username?.charAt(0).toUpperCase()}
					</div>
				)}
				<h2 class="text-2xl font-bold">{profile?.username}</h2>
				<span class="text-white/50 text-sm font-mono">{profile?.email}</span>
			</div>

			<div class="space-y-6">
				<div class="flex justify-between items-center py-4 border-b border-white/10">
					<span class="text-white/40">Username</span>
					<span class="font-medium">{profile?.username}</span>
				</div>

				<div class="flex justify-between items-center py-4 border-b border-white/10">
					<span class="text-white/40">Bio</span>
					<span class="font-medium text-white/70">{profile?.bio || 'No bio set'}</span>
				</div>

				<div class="flex justify-between items-center py-4 border-b border-white/10">
					<span class="text-white/40">Role</span>
					<span class={`px-3 py-1 rounded-full text-sm font-medium ${profile?.role === 'admin' ? 'bg-accent-cyan/20 text-accent-cyan' : 'bg-white/10 text-white/70'}`}>
						{profile?.role}
					</span>
				</div>
			</div>
		</div>
	</div>
</Layout>