---
import Layout from '../layouts/Layout.astro';
import GeneralChat from '../components/GeneralChat';

const user = Astro.locals.user;
const profile = Astro.locals.profile;

const error = Astro.url.searchParams.get('error');
---

<Layout title="Secure Terminal" hideNav={!!user}>
	{user ? (
		<div class="h-full flex flex-col bg-white overflow-hidden">
			{/* High-Contrast Top Navigation */}
			<header class="bg-white border-b-3 border-elite-black px-12 py-6">
				<div class="max-w-screen-2xl mx-auto flex items-center justify-between">
					<div class="flex items-center gap-8 group cursor-pointer">
						<div class="w-14 h-14 bg-elite-black rounded-none flex items-center justify-center shadow-[6px_6px_0px_0px_rgba(0,0,0,0.1)] transition-all group-hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] group-hover:-translate-x-1 group-hover:-translate-y-1">
							<span class="text-white font-black text-3xl tracking-tightest">C</span>
						</div>
						<div>
							<h1 class="text-2xl font-black text-elite-black tracking-tightest uppercase">Network Central</h1>
							<p class="text-[9px] font-bold text-elite-neutral-400 uppercase tracking-[0.4em]">Node Connection Established</p>
						</div>
					</div>

					<nav class="flex items-center gap-12">
						<div class="hidden lg:flex items-center gap-10">
							<a href="/chat" class="text-[10px] font-black uppercase tracking-widest hover:line-through">Secure Messages</a>
							<a href="/chat/rooms" class="text-[10px] font-black uppercase tracking-widest hover:line-through">Public Channels</a>
							<a href="/profile" class="text-[10px] font-black uppercase tracking-widest hover:line-through">Protocol Settings</a>
						</div>
						<div class="flex items-center gap-6 border-l-2 border-elite-neutral-100 pl-10">
							<div class="text-right hidden sm:block">
								<p class="text-[10px] font-black text-elite-black uppercase tracking-tighter">{profile?.username || user.email}</p>
								<div class="flex items-center justify-end gap-2 mt-1">
									<span class="w-1 h-1 bg-green-500 rounded-full"></span>
									<span class="text-[8px] font-mono font-bold text-green-600 uppercase">Signal Active</span>
								</div>
							</div>
							<form action="/api/auth/signout" method="post">
								<button type="submit" aria-label="Terminate Session" class="p-3 elite-border hover:bg-red-500 hover:text-white transition-all active:scale-90">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
									</svg>
								</button>
							</form>
						</div>
					</nav>
				</div>
			</header>

			{/* Main Content */}
			<main class="flex-1 p-12 overflow-hidden">
				<div class="max-w-screen-2xl mx-auto h-full flex gap-12">
					{/* Sidebar Welcome & Stats */}
					<div class="w-80 hidden xl:flex flex-col gap-8">
						<div class="elite-card !p-8 bg-elite-neutral-50/50">
							<span class="text-[8px] font-black uppercase tracking-[0.4em] text-elite-neutral-400 block mb-2">Protocol 7-G</span>
							<h2 class="text-3xl font-black text-elite-black uppercase tracking-tightest leading-none mb-6">
								Welcome, <br/>{profile?.username || 'User'}
							</h2>
							<p class="text-[10px] font-medium text-elite-neutral-500 uppercase leading-loose tracking-widest">
								Global transmission channel open. Awaiting peer signals.
							</p>
						</div>
						
						<div class="grid grid-cols-1 gap-4">
							<div class="elite-card !p-6 bg-white hover:bg-elite-black hover:text-white group">
								<p class="text-[8px] font-black uppercase tracking-widest text-elite-neutral-400 group-hover:text-white/50 mb-1">Active Nodes</p>
								<p class="text-3xl font-black uppercase tracking-tighter">01</p>
							</div>
							<div class="elite-card !p-6 bg-white hover:bg-elite-black hover:text-white group">
								<p class="text-[8px] font-black uppercase tracking-widest text-elite-neutral-400 group-hover:text-white/50 mb-1">Global Latency</p>
								<p class="text-3xl font-black uppercase tracking-tighter">14MS</p>
							</div>
						</div>

						<div class="mt-auto border-t-2 border-elite-black pt-8">
							<p class="text-[8px] font-mono font-bold text-elite-neutral-400 uppercase tracking-widest mb-1">Encryption Protocol</p>
							<p class="text-[10px] font-black uppercase">AES-256-BIT SECURE</p>
						</div>
					</div>

					{/* Chat Container */}
					<div class="flex-1 flex flex-col min-w-0">
						<div class="flex-1 overflow-hidden shadow-[32px_32px_0px_0px_rgba(0,0,0,0.03)] border-3 border-elite-black">
							<GeneralChat
								client:load
								currentUser={{
									id: user.id,
									email: user.email || '',
									username: profile?.username
								}}
							/>
						</div>
					</div>
				</div>
			</main>
		</div>
	) : (
		<div class="min-h-screen bg-white flex flex-col font-sans">
			{/* Grid Background Overlay */}
			<div class="fixed inset-0 z-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 40px 40px;"></div>

			<div class="max-w-screen-2xl mx-auto px-12 pt-40 pb-32 relative z-10 flex-1 flex flex-col justify-center">
				{error && (
					<div class="max-w-xl mb-20 bg-elite-black text-white p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,0.1)]">
						<div class="flex items-center gap-6">
							<div class="w-12 h-12 elite-border border-white flex items-center justify-center flex-shrink-0">
								<X class="w-6 h-6 text-white" />
							</div>
							<div>
								<p class="text-[8px] font-black uppercase tracking-[0.4em] text-white/50 mb-1">System Error</p>
								<p class="text-sm font-bold uppercase tracking-tightest leading-none">{error}</p>
							</div>
						</div>
					</div>
				)}

				{/* Hero Section */}
				<div class="max-w-5xl">
					<div class="inline-flex items-center gap-4 border-b-3 border-elite-black pb-4 mb-12">
						<div class="w-3 h-3 bg-elite-black animate-ping"></div>
						<span class="text-[10px] font-black uppercase tracking-[0.5em] text-elite-black">Signal Search: Protocol Active</span>
					</div>

					<h1 class="text-[120px] font-black text-elite-black tracking-tightest leading-[0.8] uppercase mb-16">
						Connect<br/>
						<span class="bg-elite-black text-white px-6 py-2">Universal</span><br/>
						Real-Time
					</h1>

					<p class="text-2xl font-medium text-elite-neutral-500 max-w-3xl mb-20 leading-relaxed uppercase tracking-tighter italic">
						"High-fidelity asynchronous communication protocol designed for elite synchronization across global student networks."
					</p>

					{/* CTA Buttons */}
					<div class="flex flex-col sm:flex-row gap-8 mb-40">
						<a href="/signup" class="elite-button bg-elite-black text-white !py-8 !px-16 text-xl shadow-[12px_12px_0px_0px_rgba(0,0,0,0.2)] hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] hover:-translate-x-2 hover:-translate-y-2 text-center transition-all">
							INITIATE ACCESS
						</a>
						<a href="/login" class="elite-button bg-white text-elite-black !py-8 !px-16 text-xl hover:bg-elite-neutral-50 text-center transition-all">
							RETURNING USER
						</a>
					</div>
				</div>

				{/* Features Grid - Stark Brutalist */}
				<div class="grid lg:grid-cols-3 gap-0 border-3 border-elite-black bg-elite-black">
					<div class="bg-white p-12 hover:bg-elite-black hover:text-white group transition-all duration-300 border-r-3 border-elite-black lg:border-r-3 border-b-3 lg:border-b-0">
						<div class="w-16 h-16 elite-border flex items-center justify-center mb-10 group-hover:border-white">
							<Hash class="w-8 h-8" />
						</div>
						<h3 class="text-3xl font-black uppercase tracking-tightest mb-6">Zero Latency</h3>
						<p class="text-[10px] font-bold uppercase tracking-widest text-elite-neutral-400 leading-loose group-hover:text-white/60">
							Sub-millisecond signal distribution via distributed edge nodes. Connection persistent.
						</p>
					</div>

					<div class="bg-white p-12 hover:bg-elite-black hover:text-white group transition-all duration-300 border-r-3 border-elite-black lg:border-r-3 border-b-3 lg:border-b-0">
						<div class="w-16 h-16 elite-border flex items-center justify-center mb-10 group-hover:border-white">
							<Paperclip class="w-8 h-8" />
						</div>
						<h3 class="text-3xl font-black uppercase tracking-tightest mb-6">Data Transfer</h3>
						<p class="text-[10px] font-bold uppercase tracking-widest text-elite-neutral-400 leading-loose group-hover:text-white/60">
							Encrypted object storage for seamless asset transmission across all network peers.
						</p>
					</div>

					<div class="bg-white p-12 hover:bg-elite-black hover:text-white group transition-all duration-300 border-b-0">
						<div class="w-16 h-16 elite-border flex items-center justify-center mb-10 group-hover:border-white">
							<Users class="w-8 h-8" />
						</div>
						<h3 class="text-3xl font-black uppercase tracking-tightest mb-6">AES-256 SECURE</h3>
						<p class="text-[10px] font-bold uppercase tracking-widest text-elite-neutral-400 leading-loose group-hover:text-white/60">
							End-to-end data integrity verification. Privacy is the default protocol configuration.
						</p>
					</div>
				</div>
			</div>

			<footer class="p-12 border-t-3 border-elite-black bg-white relative z-10">
				<div class="max-w-screen-2xl mx-auto flex justify-between items-center">
					<p class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">© 2026 CHATTOGETHER NETWORK • ALL SIGNALS SECURED</p>
					<div class="flex gap-10">
						<a href="#" class="text-[8px] font-black uppercase tracking-[0.3em] hover:underline">Documentation</a>
						<a href="#" class="text-[8px] font-black uppercase tracking-[0.3em] hover:underline">API Protocol</a>
						<a href="#" class="text-[8px] font-black uppercase tracking-[0.3em] hover:underline">System Status</a>
					</div>
				</div>
			</footer>
		</div>
	)}
</Layout>
