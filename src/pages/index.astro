---
import Layout from '../layouts/Layout.astro';
import GeneralChat from '../components/GeneralChat';

const user = Astro.locals.user;
const profile = Astro.locals.profile;

const error = Astro.url.searchParams.get('error');
---

<Layout title="ChatTogether" hideNav={!!user}>
	{user ? (
		<div class="h-full flex flex-col bg-surface-primary overflow-hidden">
			{/* Modern Header */}
			<header class="glass border-b border-white/5 px-8 py-4">
				<div class="max-w-7xl mx-auto flex items-center justify-between">
					<div class="flex items-center gap-4 group cursor-pointer">
						<div class="w-10 h-10 rounded-xl bg-gradient-to-br from-accent-cyan to-accent-purple flex items-center justify-center shadow-glow-cyan">
							<span class="text-white font-bold text-lg">C</span>
						</div>
						<div>
							<h1 class="text-xl font-bold tracking-tight">Network Hub</h1>
							<p class="text-xs text-white/40 font-mono">Connected</p>
						</div>
					</div>

					<nav class="flex items-center gap-6">
						<div class="hidden lg:flex items-center gap-2">
							<a href="/chat" class="px-4 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all">Messages</a>
							<a href="/chat/rooms" class="px-4 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all">Communities</a>
							<a href="/profile" class="px-4 py-2 text-sm font-medium text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all">Profile</a>
						</div>
						<div class="flex items-center gap-4 pl-6 border-l border-white/10">
							<div class="text-right hidden sm:block">
								<p class="text-sm font-medium text-white">{profile?.username || user.email}</p>
								<div class="flex items-center justify-end gap-2 mt-0.5">
									<span class="w-2 h-2 bg-accent-emerald rounded-full animate-pulse"></span>
									<span class="text-xs text-accent-emerald font-mono">Online</span>
								</div>
							</div>
							<form action="/api/auth/signout" method="post">
								<button type="submit" class="p-2.5 rounded-lg bg-white/5 hover:bg-red-500/20 hover:text-red-400 text-white/60 transition-all">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
									</svg>
								</button>
							</form>
						</div>
					</nav>
				</div>
			</header>

			{/* Main Content */}
			<main class="flex-1 p-6 overflow-hidden">
				<div class="max-w-7xl mx-auto h-full flex gap-6">
					{/* Sidebar */}
					<div class="w-72 hidden xl:flex flex-col gap-4">
						<div class="glass-card p-6">
							<p class="text-xs text-white/40 font-mono mb-2">Welcome back</p>
							<h2 class="text-2xl font-bold mb-2">{profile?.username || 'User'}</h2>
							<p class="text-sm text-white/60">Ready to connect with your network</p>
						</div>

						<div class="grid grid-cols-2 gap-3">
							<div class="glass-card p-4 hover:border-accent-cyan/30 transition-all cursor-pointer group">
								<p class="text-xs text-white/40 mb-1">Active Chats</p>
								<p class="text-2xl font-bold text-accent-cyan group-hover:text-accent-cyan/80">3</p>
							</div>
							<div class="glass-card p-4 hover:border-accent-purple/30 transition-all cursor-pointer group">
								<p class="text-xs text-white/40 mb-1">Messages</p>
								<p class="text-2xl font-bold text-accent-purple group-hover:text-accent-purple/80">24</p>
							</div>
						</div>

						<div class="glass-card p-4 mt-auto">
							<div class="flex items-center gap-3">
								<div class="w-3 h-3 rounded-full bg-accent-emerald animate-pulse"></div>
								<span class="text-sm text-white/70 font-mono">System operational</span>
							</div>
						</div>
					</div>

					{/* Chat Container */}
					<div class="flex-1 flex flex-col min-w-0">
						<div class="flex-1 overflow-hidden rounded-2xl glass-card border border-white/10">
							<GeneralChat
								client:load
								currentUser={{
									id: user.id,
									email: user.email || '',
									username: profile?.username
								}}
							/>
						</div>
					</div>
				</div>
			</main>
		</div>
	) : (
		<div class="min-h-screen bg-surface-primary flex flex-col relative overflow-hidden">
			{/* Animated Background */}
			<div class="fixed inset-0 pointer-events-none">
				<div class="absolute inset-0 bg-gradient-to-br from-surface-primary via-surface-secondary to-surface-primary"></div>
				<div class="absolute top-0 -left-40 w-96 h-96 bg-accent-cyan/20 rounded-full blur-3xl animate-pulse-slow"></div>
				<div class="absolute bottom-0 -right-40 w-96 h-96 bg-accent-purple/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent-pink/5 rounded-full blur-3xl animate-float"></div>
			</div>

			<div class="max-w-7xl mx-auto px-8 pt-24 pb-16 relative z-10 flex-1 flex flex-col">
				{error && (
					<div class="max-w-md mb-12 glass-card border-red-500/30 p-6">
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-lg bg-red-500/20 flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div>
								<p class="text-sm font-medium text-red-400">Error</p>
								<p class="text-xs text-white/60">{error}</p>
							</div>
						</div>
					</div>
				)}

				{/* Hero Section */}
				<div class="max-w-4xl mx-auto text-center py-20">
					<div class="inline-flex items-center gap-3 glass px-4 py-2 rounded-full mb-8">
						<span class="w-2 h-2 rounded-full bg-accent-cyan animate-pulse"></span>
						<span class="text-sm font-medium text-white/80">Real-time messaging</span>
					</div>

					<h1 class="text-6xl md:text-7xl font-bold mb-8 leading-tight">
						<span class="text-white">Connect</span>
						<span class="gradient-text"> instantly</span>
					</h1>

					<p class="text-xl text-white/60 max-w-2xl mx-auto mb-12 leading-relaxed">
						Experience seamless communication with your community. Fast, secure, and beautifully designed.
					</p>

					{/* CTA Buttons */}
					<div class="flex flex-col sm:flex-row gap-4 justify-center mb-20">
						<a href="/signup" class="btn-primary text-lg !px-10 !py-4">
							Start Chatting
						</a>
						<a href="/login" class="btn-secondary text-lg !px-10 !py-4">
							Welcome Back
						</a>
					</div>
				</div>

				{/* Features Grid */}
				<div class="grid md:grid-cols-3 gap-6 mt-auto">
					<div class="glass-card group hover:border-accent-cyan/30 transition-all duration-300 p-8">
						<div class="w-14 h-14 rounded-xl bg-gradient-to-br from-accent-cyan/20 to-accent-cyan/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg class="w-7 h-7 text-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Lightning Fast</h3>
						<p class="text-white/50 text-sm leading-relaxed">
							Instant message delivery with real-time synchronization across all devices.
						</p>
					</div>

					<div class="glass-card group hover:border-accent-purple/30 transition-all duration-300 p-8">
						<div class="w-14 h-14 rounded-xl bg-gradient-to-br from-accent-purple/20 to-accent-purple/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg class="w-7 h-7 text-accent-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">End-to-End Encrypted</h3>
						<p class="text-white/50 text-sm leading-relaxed">
							Your conversations are secured with industry-leading encryption protocols.
						</p>
					</div>

					<div class="glass-card group hover:border-accent-pink/30 transition-all duration-300 p-8">
						<div class="w-14 h-14 rounded-xl bg-gradient-to-br from-accent-pink/20 to-accent-pink/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg class="w-7 h-7 text-accent-pink" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a4 4 0 11-8 0 4 4 0 018 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
							</svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Community Rooms</h3>
						<p class="text-white/50 text-sm leading-relaxed">
							Join group conversations and collaborate with your team in real-time.
						</p>
					</div>
				</div>
			</div>

			<footer class="p-8 border-t border-white/5 relative z-10">
				<div class="max-w-7xl mx-auto flex justify-between items-center">
					<p class="text-sm text-white/40">© 2026 ChatTogether</p>
					<div class="flex gap-6">
						<a href="#" class="text-sm text-white/40 hover:text-white transition-colors">Privacy</a>
						<a href="#" class="text-sm text-white/40 hover:text-white transition-colors">Terms</a>
					</div>
				</div>
			</footer>
		</div>
	)}
</Layout>