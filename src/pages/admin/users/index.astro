---
import Layout from '../../../layouts/Layout.astro';
import { ChevronLeft } from 'lucide-react';

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

// Extra check just in case, though middleware handles this
const { data: profile } = await supabase
  .from('profiles')
  .select('role')
  .eq('id', user?.id)
  .maybeSingle();

if (profile?.role !== 'admin') {
  return Astro.redirect('/');
}

// Handle actions (Ban/Unban/Delete)
if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    const targetUserId = formData.get('userId')?.toString();
    const action = formData.get('action')?.toString();

    if (targetUserId && action) {
        if (action === 'ban') {
            await supabase.from('profiles').update({ is_banned: true }).eq('id', targetUserId);
        } else if (action === 'unban') {
            await supabase.from('profiles').update({ is_banned: false }).eq('id', targetUserId);
        } else if (action === 'make_admin') {
            await supabase.from('profiles').update({ role: 'admin' }).eq('id', targetUserId);
        }
    }
}

// Fetch all users
const { data: allUsers } = await supabase
  .from('profiles')
  .select('*')
  .order('created_at', { ascending: false });

---

<Layout title="Node Management">
  <div class="p-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b-3 border-elite-black pb-12 mb-16">
      <div>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-elite-neutral-400 mb-2 block">Network Supervision</span>
        <h1 class="text-6xl font-black text-elite-black tracking-tightest uppercase leading-none">Node Registry</h1>
      </div>
      <a href="/admin" class="text-[10px] font-black uppercase underline hover:line-through flex items-center gap-3 group">
          <ChevronLeft className="h-4 w-4 transition-transform group-hover:-translate-x-1" />
          Protocol Dashboard
      </a>
    </div>

    <div class="bg-white elite-border overflow-hidden shadow-[24px_24px_0px_0px_rgba(0,0,0,0.03)]">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-elite-black">
          <thead class="bg-elite-neutral-50/50">
            <tr>
              <th class="px-8 py-5 text-left text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Node Identity</th>
              <th class="px-8 py-5 text-left text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Auth Level</th>
              <th class="px-8 py-5 text-left text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Status</th>
              <th class="px-8 py-5 text-right text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Directives</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-elite-neutral-100">
            {allUsers?.map((u) => (
              <tr class="hover:bg-elite-neutral-50 transition-colors">
                <td class="px-8 py-6 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10 elite-border bg-elite-black text-white flex items-center justify-center font-black text-xs">
                      {u.avatar_url ? (
                          <img class="h-full w-full object-cover" src={u.avatar_url} alt="" />
                      ) : (
                          u.username.charAt(0).toUpperCase()
                      )}
                    </div>
                    <div class="ml-4">
                      <div class="text-[10px] font-black uppercase tracking-tightest">{u.username}</div>
                      <div class="text-[8px] font-mono font-bold text-elite-neutral-400">{u.email}</div>
                    </div>
                  </div>
                </td>
                <td class="px-8 py-6 whitespace-nowrap">
                  <span class={`elite-border px-3 py-1 text-[8px] font-black uppercase tracking-widest ${u.role === 'admin' ? 'bg-elite-black text-white shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)]' : 'bg-white text-elite-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]'}`}>
                    {u.role}
                  </span>
                </td>
                <td class="px-8 py-6 whitespace-nowrap">
                  <span class={`text-[8px] font-black uppercase tracking-[0.2em] ${u.is_banned ? 'text-red-600' : 'text-green-600'}`}>
                    {u.is_banned ? 'TERMINATED' : 'PERSISTENT'}
                  </span>
                </td>
                <td class="px-8 py-6 whitespace-nowrap text-right">
                  <div class="flex justify-end gap-3">
                    <form method="post" class="flex gap-3">
                      <input type="hidden" name="userId" value={u.id} />
                      {u.is_banned ? (
                        <button type="submit" name="action" value="unban" class="text-[8px] font-black uppercase tracking-widest bg-green-500 text-white px-3 py-1.5 elite-border shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:bg-green-600 transition-all">REINSTATE</button>
                      ) : (
                        <button type="submit" name="action" value="ban" class="text-[8px] font-black uppercase tracking-widest bg-red-500 text-white px-3 py-1.5 elite-border shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:bg-red-600 transition-all" disabled={u.id === user?.id}>TERMINATE</button>
                      )}
                      {u.role !== 'admin' && (
                        <button type="submit" name="action" value="make_admin" class="text-[8px] font-black uppercase tracking-widest bg-white text-elite-black px-3 py-1.5 elite-border shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:bg-elite-black hover:text-white transition-all">ELEVATE</button>
                      )}
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
