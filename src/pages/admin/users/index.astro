---
import Layout from '../../../layouts/Layout.astro';
import { AdminService } from '../../../services/admin.service';
import { logger } from '../../../utils/logger';
import { ChevronLeft, Shield } from 'lucide-react';

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const profile = Astro.locals.profile;

if (profile?.role !== 'admin') {
  return Astro.redirect('/');
}

const adminService = new AdminService(Astro.locals.supabase);
let errorMessage = '';
let successMessage = '';

// Handle actions (Ban/Unban/Elevate/Demote/Delete)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const targetUserId = formData.get('userId')?.toString();
    const action = formData.get('action')?.toString();

    if (targetUserId && action) {
      if (action === 'ban') {
        await adminService.toggleBan(targetUserId, true);
        successMessage = 'User terminated successfully';
      } else if (action === 'unban') {
        await adminService.toggleBan(targetUserId, false);
        successMessage = 'User reinstated successfully';
      } else if (action === 'make_admin') {
        await adminService.promoteToAdmin(targetUserId);
        successMessage = 'User elevated to admin';
      } else if (action === 'demote') {
        await adminService.demoteToUser(targetUserId);
        successMessage = 'User demoted to user role';
      } else if (action === 'delete') {
        await adminService.deleteUser(targetUserId);
        successMessage = 'User permanently deleted';
      }
    }
  } catch (err: any) {
    logger.error(err, 'Admin action failed');
    errorMessage = err.message;
  }
}

// Fetch all users
const allUsers = await adminService.getAllUsers();
---

<Layout title="Node Registry">
  <div class="min-h-screen bg-surface-primary p-4 sm:p-8">
    {/* Header */}
    <div class="flex items-center gap-4 mb-10">
      <a href="/admin" class="p-3 hover:bg-white/5 rounded-xl transition-colors">
        <ChevronLeft className="w-6 h-6 text-white/40" />
      </a>
      <div>
        <div class="flex items-center gap-3 mb-2">
          <Shield className="w-5 h-5 text-accent-cyan animate-pulse" />
          <span class="text-[10px] font-bold text-accent-cyan uppercase tracking-[0.3em]">Network Supervision</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tighter uppercase italic">Node Registry</h1>
      </div>
    </div>

    {errorMessage && (
      <div class="glass-dark border-accent-pink/30 bg-accent-pink/10 p-4 rounded-2xl mb-6 flex items-center gap-3">
        <span class="text-accent-pink text-sm font-bold uppercase">{errorMessage}</span>
      </div>
    )}

    {successMessage && (
      <div class="glass-dark border-accent-emerald/30 bg-accent-emerald/10 p-4 rounded-2xl mb-6 flex items-center gap-3">
        <span class="text-accent-emerald text-sm font-bold uppercase">{successMessage}</span>
      </div>
    )}

    {/* Users Table */}
    <div class="glass-dark border border-white/10 rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-white/[0.02] border-b border-white/5">
            <tr>
              <th class="px-6 py-4 text-left text-[10px] font-bold text-white/40 uppercase tracking-widest">Node Identity</th>
              <th class="px-6 py-4 text-left text-[10px] font-bold text-white/40 uppercase tracking-widest">Auth Level</th>
              <th class="px-6 py-4 text-left text-[10px] font-bold text-white/40 uppercase tracking-widest">Status</th>
              <th class="px-6 py-4 text-left text-[10px] font-bold text-white/40 uppercase tracking-widest">Last Active</th>
              <th class="px-6 py-4 text-right text-[10px] font-bold text-white/40 uppercase tracking-widest">Directives</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {allUsers?.map((u) => (
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-accent-cyan to-accent-blue flex items-center justify-center font-bold text-surface-primary text-sm">
                      {u.username?.[0].toUpperCase()}
                    </div>
                    <div>
                      <p class="font-bold text-sm">{u.username}</p>
                      <p class="text-[10px] text-white/40 font-mono">{u.email}</p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest ${u.role === 'admin' ? 'bg-accent-cyan/20 text-accent-cyan border border-accent-cyan/30' : 'bg-white/5 text-white/40 border border-white/10'}`}>
                    {u.role}
                  </span>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <span class={`w-2 h-2 rounded-full ${u.is_banned ? 'bg-accent-pink' : 'bg-accent-emerald'}`}></span>
                    <span class={`text-[10px] font-bold uppercase tracking-widest ${u.is_banned ? 'text-accent-pink' : 'text-accent-emerald'}`}>
                      {u.is_banned ? 'Terminated' : 'Active'}
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-[10px] text-white/40 font-mono">
                    {u.last_seen ? new Date(u.last_seen).toLocaleDateString() : 'Never'}
                  </span>
                </td>
                <td class="px-6 py-4 text-right">
                  <form method="post" class="flex justify-end gap-2">
                    <input type="hidden" name="userId" value={u.id} />
                    {u.is_banned ? (
                      <button type="submit" name="action" value="unban" class="p-2 rounded-xl bg-accent-emerald/10 text-accent-emerald hover:bg-accent-emerald/20 transition-all text-[10px] font-bold uppercase">
                        Reinstate
                      </button>
                    ) : (
                      <button type="submit" name="action" value="ban" class="p-2 rounded-xl bg-accent-pink/10 text-accent-pink hover:bg-accent-pink/20 transition-all text-[10px] font-bold uppercase disabled:opacity-30" disabled={u.id === user?.id}>
                        Terminate
                      </button>
                    )}
                    {u.role === 'admin' ? (
                      <button type="submit" name="action" value="demote" class="p-2 rounded-xl bg-white/5 text-white/40 hover:bg-white/10 transition-all text-[10px] font-bold uppercase" disabled={u.id === user?.id}>
                        Demote
                      </button>
                    ) : (
                      <button type="submit" name="action" value="make_admin" class="p-2 rounded-xl bg-accent-cyan/10 text-accent-cyan hover:bg-accent-cyan/20 transition-all text-[10px] font-bold uppercase">
                        Elevate
                      </button>
                    )}
                    <button type="submit" name="action" value="delete" class="p-2 rounded-xl bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-all text-[10px] font-bold uppercase" disabled={u.id === user?.id} onclick="return confirm('Permanently delete this user?')">
                      Delete
                    </button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>