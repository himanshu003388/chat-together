---
import Layout from '../../layouts/Layout.astro';

// Extra check just in case, though middleware handles this
const user = Astro.locals.user;
const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('role')
  .eq('id', user?.id)
  .maybeSingle();

if (profile?.role !== 'admin') {
  return Astro.redirect('/');
}

// Fetch stats
const { count: userCount } = await Astro.locals.supabase
  .from('profiles')
  .select('*', { count: 'exact', head: true });

const { count: messageCount } = await Astro.locals.supabase
  .from('messages')
  .select('*', { count: 'exact', head: true });

const { data: recentUsers } = await Astro.locals.supabase
  .from('profiles')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(5);

---

<Layout title="Authority Command">
  <div class="p-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b-3 border-elite-black pb-12 mb-16">
      <div>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-elite-neutral-400 mb-2 block">System Oversight</span>
        <h1 class="text-6xl font-black text-elite-black tracking-tightest uppercase leading-none">Command Center</h1>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      <div class="elite-card bg-white flex items-center group">
          <div class="w-16 h-16 elite-border flex items-center justify-center bg-elite-black text-white mr-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,0.1)] group-hover:bg-white group-hover:text-elite-black transition-all">
              <Users class="w-8 h-8" />
          </div>
          <div>
              <p class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Total Nodes</p>
              <p class="text-4xl font-black text-elite-black tracking-tighter leading-none">{userCount}</p>
          </div>
      </div>
      <div class="elite-card bg-white flex items-center group">
          <div class="w-16 h-16 elite-border flex items-center justify-center bg-elite-black text-white mr-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,0.1)] group-hover:bg-white group-hover:text-elite-black transition-all">
              <Hash class="w-8 h-8" />
          </div>
          <div>
              <p class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Data Packets</p>
              <p class="text-4xl font-black text-elite-black tracking-tighter leading-none">{messageCount}</p>
          </div>
      </div>
    </div>

    <div class="bg-white elite-border overflow-hidden shadow-[24px_24px_0px_0px_rgba(0,0,0,0.03)]">
      <div class="p-8 border-b border-elite-black flex justify-between items-center bg-elite-neutral-50">
          <h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-elite-black">Recent Signal Activations</h2>
          <a href="/admin/users" class="text-[10px] font-black uppercase underline hover:line-through">Access All Nodes</a>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-elite-black">
          <thead class="bg-white">
            <tr>
              <th class="px-8 py-5 text-left text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Node Identity</th>
              <th class="px-8 py-5 text-left text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Auth Level</th>
              <th class="px-8 py-5 text-left text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Activation</th>
              <th class="px-8 py-5 text-left text-[8px] font-black text-elite-neutral-400 uppercase tracking-[0.4em]">Status</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-elite-neutral-100">
            {recentUsers?.map((u) => (
              <tr class="hover:bg-elite-neutral-50 transition-colors">
                <td class="px-8 py-6 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10 elite-border bg-elite-black text-white flex items-center justify-center font-black text-xs">
                      {u.avatar_url ? (
                          <img class="h-full w-full object-cover" src={u.avatar_url} alt="" />
                      ) : (
                          u.username.charAt(0).toUpperCase()
                      )}
                    </div>
                    <div class="ml-4">
                      <div class="text-[10px] font-black uppercase tracking-tightest">{u.username}</div>
                      <div class="text-[8px] font-mono font-bold text-elite-neutral-400">{u.email}</div>
                    </div>
                  </div>
                </td>
                <td class="px-8 py-6 whitespace-nowrap">
                  <span class={`elite-border px-3 py-1 text-[8px] font-black uppercase tracking-widest ${u.role === 'admin' ? 'bg-elite-black text-white' : 'bg-white text-elite-black'}`}>
                    {u.role}
                  </span>
                </td>
                <td class="px-8 py-6 whitespace-nowrap text-[8px] font-mono font-bold uppercase text-elite-neutral-500">
                  {new Date(u.created_at).toISOString().split('T')[0]}
                </td>
                <td class="px-8 py-6 whitespace-nowrap">
                  <span class={`text-[8px] font-black uppercase tracking-[0.2em] ${u.is_banned ? 'text-red-600' : 'text-green-600'}`}>
                    {u.is_banned ? 'TERMINATED' : 'PERSISTENT'}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
