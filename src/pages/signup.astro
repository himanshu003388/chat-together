---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/');
}

const error = Astro.url.searchParams.get('error');
---

<Layout title="Initialize Identity">
	<div class="min-h-full flex items-center justify-center py-24 px-6 lg:px-8 bg-elite-neutral-50/50 relative">
		{/* Background Grid */}
		<div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 40px 40px;"></div>

		<div class="max-w-xl w-full space-y-12 bg-white p-16 elite-border shadow-[24px_24px_0px_0px_rgba(0,0,0,0.05)] relative z-10">
			<div>
				<div class="w-12 h-1 bg-elite-black mb-8"></div>
				<h2 class="text-5xl font-black text-elite-black tracking-tightest uppercase leading-none">
					Network<br/>Registration
				</h2>
				<p class="mt-4 text-[10px] font-bold text-elite-neutral-400 uppercase tracking-[0.3em]">
					Request New Identity Protocol
				</p>
			</div>

			{error && (
				<div class="bg-elite-black text-white p-6 elite-border shadow-[8px_8px_0px_0px_rgba(0,0,0,0.1)]">
					<p class="text-[10px] font-black uppercase tracking-widest">{error}</p>
				</div>
			)}

			<form class="mt-12 space-y-10" action="/api/auth/signup" method="post">
				<div class="space-y-8">
					<div class="space-y-3">
						<label for="username" class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Identity Alias</label>
						<input id="username" name="username" type="text" autocomplete="username" required minlength="3" maxlength="30" pattern="[a-zA-Z0-9_]+" class="w-full bg-elite-neutral-50 elite-border px-6 py-4 focus:bg-white focus:ring-12 focus:ring-elite-black/5 transition-all outline-none font-bold uppercase tracking-tighter" placeholder="ALIAS_01">
						<p class="text-[8px] font-mono font-bold text-elite-neutral-400 uppercase tracking-widest">ALPHANUMERIC + UNDERSCORES ONLY</p>
					</div>
					<div class="space-y-3">
						<label for="email-address" class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Email Vector</label>
						<input id="email-address" name="email" type="email" autocomplete="email" required class="w-full bg-elite-neutral-50 elite-border px-6 py-4 focus:bg-white focus:ring-12 focus:ring-elite-black/5 transition-all outline-none font-bold uppercase tracking-tighter" placeholder="IDENTITY@NETWORK.COM">
					</div>
					<div class="space-y-3">
						<label for="password" class="text-[10px] font-black uppercase tracking-widest text-elite-neutral-400">Security Key</label>
						<input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" class="w-full bg-elite-neutral-50 elite-border px-6 py-4 focus:bg-white focus:ring-12 focus:ring-elite-black/5 transition-all outline-none font-bold tracking-tighter" placeholder="MINIMUM 8 CHARACTERS">
					</div>
				</div>

				<div class="pt-4">
					<button type="submit" class="elite-button w-full bg-elite-black text-white text-lg py-5 shadow-[8px_8px_0px_0px_rgba(0,0,0,0.2)] hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:-translate-x-1 hover:-translate-y-1 transition-all">
						INITIALIZE REGISTRATION
					</button>
				</div>
			</form>
			<div class="text-center pt-4 border-t border-elite-neutral-100">
				<a href="/login" class="text-[9px] font-black uppercase tracking-[0.3em] text-elite-neutral-400 hover:text-elite-black hover:line-through transition-all">Returning Protocol User</a>
			</div>
		</div>
	</div>
</Layout>