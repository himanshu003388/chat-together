---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/');
}

const error = Astro.url.searchParams.get('error');
const message = Astro.url.searchParams.get('message');
const emailParam = Astro.url.searchParams.get('email') || '';
---

<Layout title="Login">
	<div class="min-h-full flex items-center justify-center py-12 px-6 relative">
		{/* Background Effects */}
		<div class="fixed inset-0 pointer-events-none">
			<div class="absolute top-20 -left-60 w-96 h-96 bg-accent-cyan/15 rounded-full blur-3xl"></div>
			<div class="absolute bottom-20 -right-60 w-96 h-96 bg-accent-purple/15 rounded-full blur-3xl"></div>
		</div>

		<div class="max-w-md w-full space-y-8 glass-card p-10 relative z-10">
			<div class="text-center">
				<div class="mx-auto w-16 h-16 rounded-2xl bg-gradient-to-br from-accent-cyan to-accent-purple flex items-center justify-center mb-6 shadow-glow-cyan">
					<svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
					</svg>
				</div>
				<h2 class="text-3xl font-bold">Welcome back</h2>
				<p class="mt-2 text-white/50 text-sm">Sign in to continue to your account</p>
			</div>

			{error && (
				<div class="glass border-red-500/30 p-4 rounded-lg">
					<p class="text-red-400 text-sm">{error}</p>
				</div>
			)}
			{message && (
				<div class="glass border-accent-cyan/30 p-4 rounded-lg">
					<p class="text-accent-cyan text-sm">{message}</p>
				</div>
			)}
			{(error?.includes('confirm') || message?.includes('confirm')) && emailParam && (
				<form action="/api/auth/resend" method="post" class="mt-4">
					<input type="hidden" name="email" value={emailParam} />
					<p class="text-sm text-white/60">
						Didn't receive the email?
						<button type="submit" class="text-accent-cyan hover:underline ml-1">Resend</button>
					</p>
				</form>
			)}

			<form class="mt-8 space-y-6" action="/api/auth/signin" method="post">
				<div class="space-y-5">
					<div>
						<label for="email-address" class="text-sm font-medium text-white/70 mb-2 block">Email</label>
						<input id="email-address" name="email" type="email" autocomplete="email" required class="input-glass" placeholder="you@example.com">
					</div>
					<div>
						<label for="password" class="text-sm font-medium text-white/70 mb-2 block">Password</label>
						<input id="password" name="password" type="password" autocomplete="current-password" required class="input-glass" placeholder="••••••••">
					</div>
				</div>

				<div>
					<button type="submit" class="btn-primary w-full !py-3.5">
						Sign In
					</button>
				</div>
			</form>

			<div class="text-center">
				<p class="text-sm text-white/50">
					Don't have an account?
					<a href="/signup" class="text-accent-cyan hover:underline font-medium">Sign up</a>
				</p>
			</div>
		</div>
	</div>
</Layout>