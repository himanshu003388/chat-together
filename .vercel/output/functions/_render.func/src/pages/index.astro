---
import Layout from '../layouts/Layout.astro';
import GeneralChat from '../components/GeneralChat';

const user = Astro.locals.user;
const profile = Astro.locals.profile;

const error = Astro.url.searchParams.get('error');
---

<Layout title="Welcome to ChatApp" hideNav={!!user}>
	{user ? (
		<div class="h-full flex flex-col bg-gradient-to-br from-gray-50 to-indigo-50">
			{/* Top Navigation */}
			<header class="bg-white/80 backdrop-blur-sm border-b border-gray-200 px-6 py-4">
				<div class="max-w-7xl mx-auto flex items-center justify-between">
					<div class="flex items-center gap-4">
						<div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-xl flex items-center justify-center">
							<span class="text-white font-bold text-xl">C</span>
						</div>
						<div>
							<h1 class="text-xl font-bold text-gray-900">ChatTogether</h1>
							<p class="text-xs text-gray-500">Connect • Share • Learn</p>
						</div>
					</div>

					<nav class="flex items-center gap-6">
						<a href="/chat" class="text-gray-600 hover:text-indigo-600 transition font-medium">Messages</a>
						<a href="/profile" class="text-gray-600 hover:text-indigo-600 transition font-medium">Profile</a>
						<div class="flex items-center gap-3">
							<div class="text-right">
								<p class="text-sm font-semibold text-gray-900">{profile?.username || user.email}</p>
								<p class="text-xs text-green-600 flex items-center gap-1">
									<span class="w-2 h-2 bg-green-500 rounded-full"></span>
									Online
								</p>
							</div>
							<div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white font-bold">
								{(profile?.username || user.email?.[0] || 'U').toUpperCase()}
							</div>
							<form action="/api/auth/signout" method="post" class="ml-2">
								<button type="submit" class="text-sm text-red-500 hover:text-red-700 font-medium transition">Sign out</button>
							</form>
						</div>
					</nav>
				</div>
			</header>

			{/* Main Content */}
			<main class="flex-1 p-6 overflow-hidden">
				<div class="max-w-5xl mx-auto h-full flex flex-col">
					{/* Welcome Header */}
					<div class="mb-4 bg-white rounded-xl p-6 shadow-sm border border-gray-100">
						<div class="flex items-center justify-between">
							<div>
								<h2 class="text-2xl font-bold text-gray-900">
									Welcome back, <span class="text-indigo-600">{profile?.username || 'Student'}!</span>
								</h2>
								<p class="text-gray-500 mt-1">Join the global conversation with students worldwide.</p>
							</div>
							<div class="flex items-center gap-4">
								<div class="text-center px-4 py-2 bg-indigo-50 rounded-lg">
									<p class="text-2xl font-bold text-indigo-600">1</p>
									<p class="text-xs text-indigo-500">Room</p>
								</div>
								<div class="text-center px-4 py-2 bg-purple-50 rounded-lg">
									<p class="text-2xl font-bold text-purple-600">∞</p>
									<p class="text-xs text-purple-500">Online</p>
								</div>
							</div>
						</div>
					</div>

					{/* Chat Container */}
					<div class="flex-1 overflow-hidden">
						<GeneralChat
							client:load
							currentUser={{
								id: user.id,
								email: user.email || '',
								username: profile?.username
							}}
						/>
					</div>
				</div>
			</main>
		</div>
	) : (
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center flex-1 flex flex-col justify-center">
			{error && (
				<div class="max-w-md mx-auto mb-8 bg-red-50 border-l-4 border-red-400 p-4">
					<p class="text-sm text-red-700">{error}</p>
				</div>
			)}

			{/* Hero Section */}
			<div class="mb-12">
				<div class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 px-4 py-2 rounded-full mb-6">
					<span class="w-2 h-2 bg-indigo-500 rounded-full animate-pulse"></span>
					<span class="text-sm font-medium">For Students, By Students</span>
				</div>

				<h1 class="text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
					Connect with everyone,<br />
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">in real-time.</span>
				</h1>

				<p class="text-xl text-gray-500 max-w-2xl mx-auto mb-8">
					A fast, secure, and beautiful chat application built for student collaboration.
					Share ideas, discuss topics, and learn together.
				</p>
			</div>

			{/* Features Grid */}
			<div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-12">
				<div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
					<div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-semibold text-gray-900 mb-2">Real-time Messaging</h3>
					<p class="text-gray-500 text-sm">Instant communication with students worldwide. No delays, just conversations.</p>
				</div>

				<div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
					<div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-semibold text-gray-900 mb-2">File Sharing</h3>
					<p class="text-gray-500 text-sm">Share images, documents, and files instantly. Perfect for study materials.</p>
				</div>

				<div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
					<div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-semibold text-gray-900 mb-2">Secure & Private</h3>
					<p class="text-gray-500 text-sm">Your conversations are protected with enterprise-grade security.</p>
				</div>
			</div>

			{/* CTA Buttons */}
			<div class="flex justify-center gap-4">
				<a href="/signup" class="px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold rounded-xl hover:opacity-90 transition shadow-lg shadow-indigo-200">
					Get Started Free
				</a>
				<a href="/login" class="px-8 py-4 bg-white text-indigo-600 border-2 border-indigo-200 font-semibold rounded-xl hover:bg-indigo-50 transition">
					Log In
				</a>
			</div>
		</div>
	)}
</Layout>
